            "exec": [
              "let responseData = pm.response.json();\r",
              "pm.collectionVariables.set(\"itemId\", responseData.id);\r",
              "pm.test(\"Response status code is 200 and response time is less than 4000ms\", function () {\r",
              "    pm.expect(pm.response).to.have.status(200);\r",
              "    pm.expect(pm.response.responseTime).to.be.below(4000);\r",
              "});\r",
              "pm.test(\"Response status code is 200\", function () {\r",
              "    pm.expect(pm.response).to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an object with required properties\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    pm.expect(responseData).to.have.all.keys('id', 'name', 'data');\r",
              "});\r",
              "\r",
              "pm.test(\"Data object contains required properties\", function () {\r",
              "    const data = pm.response.json().data;\r",
              "    pm.expect(data).to.have.all.keys('year', 'price', 'CPU model', 'Hard disk size');\r",
              "});"
